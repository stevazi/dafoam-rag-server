# ── Source repository ────────────────────────────────────────────────────────
# Path to the local DAFoam clone to index (relative or absolute)
DAFOAM_REPO_PATH=../dafoam

# ── Chroma vector DBs ─────────────────────────────────────────────────────────
CHROMA_CODE_DIR=./data/chroma_code
CHROMA_DOCS_DIR=./data/chroma_docs
CHROMA_TESTS_DIR=./data/chroma_tests
CHROMA_COLLECTION_CODE=dafoam_code
CHROMA_COLLECTION_DOCS=dafoam_docs
CHROMA_COLLECTION_TESTS=dafoam_tests

# ── Embeddings ────────────────────────────────────────────────────────────────
# intfloat/multilingual-e5-large — already cached, works with transformers 5.x
# Note: jinaai/jina-embeddings-v2-base-code requires trust_remote_code and has
#       transformers 5.x compatibility issues (removed find_pruneable_heads_and_indices)
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_FALLBACK_MODEL=jinaai/jina-embeddings-v2-base-code
# Allow one online download retry if model is missing from local cache
EMBED_AUTO_DOWNLOAD_ON_MISS=true

# ── MCP Server ────────────────────────────────────────────────────────────────
# Port for SSE server. 29310 avoids conflict with IDG_LLM (29300).
CHROMA_MCP_PORT=29310

# ── RAG settings ──────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
